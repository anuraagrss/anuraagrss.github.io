rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasRole(role) {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // admins — each user can read their own doc; only super-admin can write
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if hasRole('super-admin');
    }

    // Chinni's rewards — rewards or super-admin
    match /sarah_achievements/{docId} {
      allow read, write: if hasRole('rewards') || hasRole('super-admin');
    }

    // Everything else — any authenticated admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
